class RadarConvBlock(nn.Module):
    def __init__(self,in_channels,out_channels):
        super().__init__()
        self.model=nn.Sequential(
            nn.Conv2d(in_channels, 128, kernel_size=3, padding=1, dilation=1),
            nn.BatchNorm2d(128),
            nn.LeakyReLU(inplace=True),
            nn.Conv2d(128, out_channels, kernel_size=3, padding=1, dilation=1),
            nn.BatchNorm2d(out_channels),
            nn.LeakyReLU(inplace=True)
        )

    def forward(self,x: torch.Tensor) -> torch.Tensor:
        x = self.model(x)
        return x
    
class Radar3DTensorEncoder(nn.Module):
    def __init__(self,input_size,output_size):
        super().__init__()
        d_in, r_in, a_in = input_size
        fd, fr, fa = output_size
        self.fr = fr
        self.fa = fa
        self.conv_block_d = RadarConvBlock(in_channels=d_in, out_channels=fd)
        self.conv_block_r = RadarConvBlock(in_channels=r_in, out_channels=fr)
        self.conv_block_a = RadarConvBlock(in_channels=a_in, out_channels=fa)
 
    def forward(self, x: torch.Tensor) : 
        f_d: torch.Tensor = self.conv_block_d(x) 
        x_r: torch.Tensor = f_d.permute(0, 2, 1, 3).contiguous()
        f_r: torch.Tensor = self.conv_block_r(x_r)    
        x_a: torch.Tensor = f_r.permute(0, 3, 2, 1).contiguous()    
        f_a: torch.Tensor = self.conv_block_a(x_a)
        x:   torch.Tensor = f_a.permute(0, 2, 3, 1).contiguous()                                           
        return x

class Radar3DTensorDecoder(nn.Module):
    def __init__(self,input_size,output_size):
        super().__init__()
        fea_c, fea_h, fea_w = input_size
        num_boxes, bbx_parameter = output_size

        self.backbone = RadarConvBlock(
            in_channels=fea_c,
            out_channels=num_boxes
        )
        self.output_head = nn.Linear(fea_h * fea_w, bbx_parameter)  #h*w -> bbx_parameter


    def forward(self, x: torch.Tensor) -> torch.Tensor:
        x = self.backbone(x) # (B, num_boxes, H, W)
        x = x.view(x.shape[0], x.shape[1], -1)  # (B, num_boxes, H*W)
        x = self.output_head(x)              # (B, num_boxes, pred_dim)
        return x
    


class MVRSS3DModel(nn.Module):
    def __init__(
            self,rad_input_size,
            rae_input_size,
            feature_size,
            det_gt_size
            ):

        super().__init__()

        self.rad_encoder = Radar3DTensorEncoder(input_size=rad_input_size, output_size=feature_size)
        self.rae_encoder = Radar3DTensorEncoder(input_size=rae_input_size, output_size=feature_size)

        self.decoder = Radar3DTensorDecoder(input_size=feature_size, output_size=det_gt_size)

        self.det_output_size = det_gt_size

        num_feature_channels, H, W = feature_size
        self.fusion = nn.Sequential(
            nn.Conv2d(num_feature_channels*2, num_feature_channels, kernel_size=3, padding=1),
            nn.BatchNorm2d(num_feature_channels),
            nn.LeakyReLU(inplace=True),
            nn.Conv2d(num_feature_channels, num_feature_channels, kernel_size=3, padding=1),
            nn.BatchNorm2d(num_feature_channels),
            nn.LeakyReLU(inplace=True)
        )

        
    def forward(self,batch):

        rad= batch['rad']
        rae= batch['rae']

        # enoder
        f_rad = self.rad_encoder(rad)
        f_rae = self.rae_encoder(rae)

        # latent feature fusion
        f_fusion = torch.cat([f_rad, f_rae], dim=1)
        fused_features = self.fusion(f_fusion)

        output = self.decoder(fused_features)
        
        return output


def build_padded_targets(
        gt_boxes_list,
        gt_labels_list,
        num_queries,
        box_dim,
        num_classes,
        device
    ):
    B = len(gt_boxes_list)

    target_boxes = torch.zeros(
        B,
        num_queries,
        box_dim,
        dtype=torch.float32,
        device=device
    )

    target_classes = torch.full(
        (B, num_queries),
        fill_value=num_classes,
        dtype=torch.long,
        device=device
    )

    positive_mask = torch.zeros(
        B,
        num_queries,
        dtype=torch.bool,
        device=device
    )

    for b in range(B):
        gt_boxes = gt_boxes_list[b].to(device)
        gt_labels = gt_labels_list[b].to(device)

        num_gt = min(gt_boxes.shape[0], num_queries)

        if num_gt == 0:
            continue

        target_boxes[b, :num_gt] = gt_boxes[:num_gt]
        target_classes[b, :num_gt] = gt_labels[:num_gt]
        positive_mask[b, :num_gt] = True

    return target_boxes, target_classes, positive_mask


def detection_loss(
        outputs,
        gt_boxes_list,
        gt_labels_list,
        num_classes,
        box_loss_weight=1.0,
        cls_loss_weight=1.0,
        background_weight=0.1
    ):
    device = outputs.device

    box_dim = 7
    num_queries = outputs.shape[1]
    expected_output_dim = box_dim + num_classes + 1

    if outputs.shape[-1] != expected_output_dim:
        raise ValueError(
            f"Expected output dim {expected_output_dim}, got {outputs.shape[-1]}"
        )

    pred_boxes = outputs[:, :, :box_dim].sigmoid()
    pred_logits = outputs[:, :, box_dim:]

    target_boxes, target_classes, positive_mask = build_padded_targets(
        gt_boxes_list=gt_boxes_list,
        gt_labels_list=gt_labels_list,
        num_queries=num_queries,
        box_dim=box_dim,
        num_classes=num_classes,
        device=device
    )

    class_weights = torch.ones(num_classes + 1, device=device)
    class_weights[-1] = background_weight

    cls_loss = F.cross_entropy(
        pred_logits.reshape(-1, num_classes + 1),
        target_classes.reshape(-1),
        weight=class_weights
    )

    if positive_mask.any():
        box_loss = F.smooth_l1_loss(
            pred_boxes[positive_mask],
            target_boxes[positive_mask]
        )
    else:
        box_loss = torch.tensor(0.0, device=device)

    total_loss = (
        box_loss_weight * box_loss
        + cls_loss_weight * cls_loss
    )

    loss_dict = {
        "total_loss": total_loss.item(),
        "box_loss": box_loss.item(),
        "cls_loss": cls_loss.item()
    }

    return total_loss, loss_dict

def boxes_rae_to_ra_xyxy(boxes):
    """
    boxes: [N, 7]
    box:
    [r_idx, a_idx, e_idx, r_width, a_width, e_width, yaw]

    return:
    [N, 4]
    [r_min, a_min, r_max, a_max]
    """
    r = boxes[:, 0]
    a = boxes[:, 1]
    r_w = boxes[:, 3]
    a_w = boxes[:, 4]

    r_min = r - r_w / 2.0
    r_max = r + r_w / 2.0
    a_min = a - a_w / 2.0
    a_max = a + a_w / 2.0

    return torch.stack([r_min, a_min, r_max, a_max], dim=-1)


def box_iou_2d(boxes1, boxes2):
    """
    boxes1: [N, 4]
    boxes2: [M, 4]
     [r_min, a_min, r_max, a_max]
    """
    if boxes1.numel() == 0 or boxes2.numel() == 0:
        return torch.zeros(
            (boxes1.shape[0], boxes2.shape[0]),
            device=boxes1.device
        )

    left_top = torch.max(boxes1[:, None, :2], boxes2[None, :, :2])
    right_bottom = torch.min(boxes1[:, None, 2:], boxes2[None, :, 2:])

    wh = (right_bottom - left_top).clamp(min=0)
    inter = wh[:, :, 0] * wh[:, :, 1]

    area1 = (
        (boxes1[:, 2] - boxes1[:, 0]).clamp(min=0)
        * (boxes1[:, 3] - boxes1[:, 1]).clamp(min=0)
    )

    area2 = (
        (boxes2[:, 2] - boxes2[:, 0]).clamp(min=0)
        * (boxes2[:, 3] - boxes2[:, 1]).clamp(min=0)
    )

    union = area1[:, None] + area2[None, :] - inter + 1e-6

    return inter / union

@torch.no_grad()
def evaluate_precision_recall(
        model,
        dataloader,
        device,
        num_classes,
        score_thresh=0.5,
        iou_thresh=0.5
    ):
    model.eval()

    total_tp = 0
    total_fp = 0
    total_fn = 0

    for batch in dataloader:
        batch["rad"] = batch["rad"].to(device)
        batch["rae"] = batch["rae"].to(device)

        outputs = model(batch)

        pred_boxes = outputs[:, :, :7].sigmoid()
        pred_logits = outputs[:, :, 7:]

        pred_probs = pred_logits.softmax(dim=-1)

        pred_scores, pred_labels = pred_probs[:, :, :num_classes].max(dim=-1)

        batch_size = pred_boxes.shape[0]

        for b in range(batch_size):
            scores_b = pred_scores[b]
            labels_b = pred_labels[b]
            boxes_b = pred_boxes[b]

            # 
            keep = scores_b > score_thresh

            pred_boxes_keep = boxes_b[keep]
            pred_labels_keep = labels_b[keep]
            pred_scores_keep = scores_b[keep]

            gt_boxes = batch["gt_boxes"][b].to(device)
            gt_labels = batch["gt_labels"][b].to(device)

            # 1
            if pred_boxes_keep.shape[0] == 0:
                total_fn += gt_boxes.shape[0]
                continue

            # 2
            if gt_boxes.shape[0] == 0:
                total_fp += pred_boxes_keep.shape[0]
                continue

            pred_ra_boxes = boxes_rae_to_ra_xyxy(pred_boxes_keep)
            gt_ra_boxes = boxes_rae_to_ra_xyxy(gt_boxes)

            ious = box_iou_2d(pred_ra_boxes, gt_ra_boxes)

            matched_gt = set()

            # 
            order = pred_scores_keep.argsort(descending=True)

            for pred_idx_tensor in order:
                pred_idx = pred_idx_tensor.item()

                iou_row = ious[pred_idx]
                best_iou, best_gt_idx_tensor = iou_row.max(dim=0)
                best_gt_idx = best_gt_idx_tensor.item()

                class_correct = (
                    pred_labels_keep[pred_idx].item()
                    == gt_labels[best_gt_idx].item()
                )

                if (
                    best_iou.item() >= iou_thresh
                    and class_correct
                    and best_gt_idx not in matched_gt
                ):
                    total_tp += 1
                    matched_gt.add(best_gt_idx)
                else:
                    total_fp += 1

            total_fn += gt_boxes.shape[0] - len(matched_gt)

    precision = total_tp / (total_tp + total_fp + 1e-6)
    recall = total_tp / (total_tp + total_fn + 1e-6)

    model.train()

    return {
        "precision": precision,
        "recall": recall,
        "tp": total_tp,
        "fp": total_fp,
        "fn": total_fn,
    }

def train_one_epoch(
        model,
        dataloader,
        optimizer,
        device,
        num_classes,
        epoch=None,
        num_epochs=None,
        box_loss_weight=1.0,
        cls_loss_weight=1.0,
        background_weight=0.1
    ):
    model.train()

    total_loss_sum = 0.0
    box_loss_sum = 0.0
    cls_loss_sum = 0.0
    num_batches = 0

    if epoch is not None and num_epochs is not None:
        desc = f"Epoch {epoch + 1}/{num_epochs}"
    else:
        desc = "Training"

    pbar = tqdm(dataloader, desc=desc, ncols=120)

    for batch in pbar:
        batch["rad"] = batch["rad"].to(device)
        batch["rae"] = batch["rae"].to(device)

        outputs = model(batch)

        loss, loss_dict = detection_loss(
            outputs=outputs,
            gt_boxes_list=batch["gt_boxes"],
            gt_labels_list=batch["gt_labels"],
            num_classes=num_classes,
            box_loss_weight=box_loss_weight,
            cls_loss_weight=cls_loss_weight,
            background_weight=background_weight
        )

        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

        total_loss_sum += loss_dict["total_loss"]
        box_loss_sum += loss_dict["box_loss"]
        cls_loss_sum += loss_dict["cls_loss"]
        num_batches += 1

        avg_loss = total_loss_sum / num_batches
        avg_box = box_loss_sum / num_batches
        avg_cls = cls_loss_sum / num_batches

        pbar.set_postfix({
            "loss": f"{avg_loss:.4f}",
            "box": f"{avg_box:.4f}",
            "cls": f"{avg_cls:.4f}",
        })

    avg_total_loss = total_loss_sum / max(num_batches, 1)
    avg_box_loss = box_loss_sum / max(num_batches, 1)
    avg_cls_loss = cls_loss_sum / max(num_batches, 1)

    return {
        "train_loss": avg_total_loss,
        "train_box_loss": avg_box_loss,
        "train_cls_loss": avg_cls_loss,
    }

if __name__ == "__main__":
    cfg = DataConfig()
    numClasses = 2

    BatchSize = 8
    num_epochs = 10

    rad_input_size = (256, 107, 64)
    rae_input_size = (256, 107, 37)
    feature_size = (128, 24, 64)

    num_boxes = 64
    det_gt_size = (num_boxes, 7 + numClasses + 1)

    radar_dataset = KRadarRADRAEDataset(
        "/run/user/1000/gvfs/smb-share:server=192.168.189.30,share=elab-share/Datasets/K-Radar-RAD",
        cfg.sequence
    )

    full_dataset = KRadarGTDetectionDataset(
        label_dir=get_label_dir(cfg),
        radar_dataset=radar_dataset,
        gt_txt_path=get_gt_txt_path(cfg)
    )

    train_ratio = 0.8
    train_size = int(len(full_dataset) * train_ratio)
    val_size = len(full_dataset) - train_size

    generator = torch.Generator().manual_seed(42)

    train_dataset, val_dataset = random_split(
        full_dataset,
        [train_size, val_size],
        generator=generator
    )

    train_loader = DataLoader(
        train_dataset,
        batch_size=BatchSize,
        shuffle=True,
        collate_fn=detection_collate,
        num_workers=0
    )

    val_loader = DataLoader(
        val_dataset,
        batch_size=BatchSize,
        shuffle=False,
        collate_fn=detection_collate,
        num_workers=0
    )

    device = "cuda" if torch.cuda.is_available() else "cpu"
    print("device:", device)
    print("full dataset size:", len(full_dataset))
    print("train size:", len(train_dataset))
    print("val size:", len(val_dataset))

    model = MVRSS3DModel(
        rad_input_size=rad_input_size,
        rae_input_size=rae_input_size,
        feature_size=feature_size,
        det_gt_size=det_gt_size
    ).to(device)

    optimizer = torch.optim.Adam(model.parameters(), lr=1e-4)
    history = []

    for epoch in range(num_epochs):
        train_metrics = train_one_epoch(
            model=model,
            dataloader=train_loader,
            optimizer=optimizer,
            device=device,
            num_classes=numClasses,
            epoch=epoch,
            num_epochs=num_epochs,
            box_loss_weight=1.0,
            cls_loss_weight=1.0,
            background_weight=0.2
        )

        val_metrics = evaluate_precision_recall(
            model=model,
            dataloader=val_loader,
            device=device,
            num_classes=numClasses,
            score_thresh=0.1,
            iou_thresh=0.1
        )

        print(
            f"Epoch [{epoch + 1}/{num_epochs}] "
            f"train_loss={train_metrics['train_loss']:.4f}, "
            f"box={train_metrics['train_box_loss']:.4f}, "
            f"cls={train_metrics['train_cls_loss']:.4f}, "
            f"val_precision={val_metrics['precision']:.4f}, "
            f"val_recall={val_metrics['recall']:.4f}, "
            f"TP={val_metrics['tp']}, "
            f"FP={val_metrics['fp']}, "
            f"FN={val_metrics['fn']}"
        )

        history.append({
            "epoch": epoch + 1,
            "train_loss": train_metrics["train_loss"],
            "box": train_metrics["train_box_loss"],
            "cls": train_metrics["train_cls_loss"],
            "val_precision": val_metrics["precision"],
            "val_recall": val_metrics["recall"],
            "tp": val_metrics["tp"],
            "fp": val_metrics["fp"],
            "fn": val_metrics["fn"],
        })

    print_training_history(history)
